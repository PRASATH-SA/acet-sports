{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "functions": {
        "backend/server.js": {
            "memory": 512,
            "maxDuration": 30
        }
    },
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/server.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}